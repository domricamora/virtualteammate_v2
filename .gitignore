# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp
*~

# Logs / temp
*.log
_*.html

# Local-only credentials (FTP, etc.) — never commit
.ftp.local
*.local
.env
.env.*
# Google Workspace SMTP credentials — server-only, never commit (template is *.example)
portal/smtp.local.php

# Portal SQLite DB — per-environment, never committed or deployed
data/portal.sqlite
data/portal.sqlite-journal
data/portal.sqlite-wal
data/portal.sqlite-shm
# Chat SQLite DB (messages) — per-environment, created on first use
data/chat.sqlite
data/chat.sqlite-journal
data/chat.sqlite-wal
data/chat.sqlite-shm
data/SUPERADMIN_CREDENTIALS.txt
# Site-cache state mirror — per-environment, written by the portal cache control
data/cache-state.php

# Synced HubSpot media (per-environment, may contain PII like resumes)
data/media/

# Public synced VT photos (web-accessible, per-environment — generated by sync)
vtmedia/

# PHP session files (per-environment runtime state)
data/sessions/

# User-uploaded profile + cover photos (per-environment user content)
data/avatars/

# User-uploaded task attachments (per-environment, may contain client docs)
data/task-attachments/

# Local agent/editor config
.claude/
