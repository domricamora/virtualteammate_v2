# Synced HubSpot media (per-environment, may contain PII like resumes)
data/media/

# Public synced VT photos (web-accessible, per-environment — generated by sync)
vtmedia/

# User-uploaded profile + cover photos (per-environment user content)
data/avatars/

# User-uploaded task attachments (per-environment, may contain client docs)
data/task-attachments/

# Local agent/editor config
.claude/
