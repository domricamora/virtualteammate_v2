<?php
/**
 * Install key — gitignored secret that unlocks FIRST-TIME setup on a remote
 * host (when no super_admin exists yet). Copy this file to install.key.php,
 * replace the value with a long random string, upload it, then run:
 *
 *     https://<host>/portal/install.php?key=YOUR_LONG_RANDOM_SECRET
 *
 * Delete install.key.php once the super admin has been created — after that the
 * installer requires a logged-in super_admin and ignores this key entirely.
 *
 * Generate a value with:  php -r "echo bin2hex(random_bytes(24));"
 */
return 'replace-with-a-long-random-secret';
