<?php
/**
 * SMTP credentials for outbound portal email.
 *
 * SETUP:
 *   1. Copy this file to  portal/smtp.local.php  (same folder).
 *   2. Fill in the SMTP host, port, and mailbox credentials from your
 *      email provider (cPanel/hosting mailbox, SendGrid, Mailgun, etc.).
 *        - Use port 587 with STARTTLS, or port 465 for implicit TLS.
 *        - 'user' / 'pass' are the SMTP login for the sending mailbox.
 *   3. Save. The portal sends via SMTP automatically once this file exists;
 *      with no file present it falls back to native PHP mail().
 *
 * SECURITY: smtp.local.php is gitignored, denied direct web access in
 * .htaccess, and excluded from deploy.sh — it lives only on the server and
 * is never committed or overwritten by a deploy. Keep this .example file
 * (placeholders only) in git as the template.
 *
 * DELIVERABILITY: publish SPF and DKIM records for virtualteammate.com that
 * authorize your sending host so relayed mail isn't flagged as spam.
 */

return [
    'host'      => 'mail.virtualteammate.com',        // your SMTP server hostname
    'port'      => 587,                               // 587 = STARTTLS, 465 = implicit TLS
    'user'      => 'support@virtualteammate.com',     // the authenticating mailbox
    'pass'      => 'your-smtp-password-here',         // SMTP password / API key
    'from'      => 'support@virtualteammate.com',     // envelope + From: address
    'from_name' => 'Virtual Teammate',
];
